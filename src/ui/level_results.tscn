[gd_scene format=3]

[node name="LevelResultsController" type="CanvasLayer"]
script = ExtResource("res://src/ui/level_results_controller.gd")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -200.0
offset_right = 160.0
offset_bottom = 200.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="Panel/VBox"]
text = "ПОБЕДА!"
horizontal_alignment = 1

[node name="StarsLabel" type="Label" parent="Panel/VBox"]
text = "★★★"
horizontal_alignment = 1

[node name="SlimeLabel" type="Label" parent="Panel/VBox"]
text = "+0 💩 SLIME"
horizontal_alignment = 1

[node name="RetryButton" type="Button" parent="Panel/VBox"]
text = "↻  ЕЩЁ РАЗ"

[node name="MenuButton" type="Button" parent="Panel/VBox"]
text = "← МЕНЮ"
